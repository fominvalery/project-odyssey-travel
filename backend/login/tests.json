{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing fields returns 400",
      "method": "POST",
      "path": "/",
      "body": {"email": "test@example.com"},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    },
    {
      "name": "Wrong credentials returns 401",
      "method": "POST",
      "path": "/",
      "body": {"email": "notexist@example.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    }
  ]
}
